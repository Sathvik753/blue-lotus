# ── Copy this to .env and fill in values ──────────────────────
# Never commit .env to git

# Database (Railway/Render will provide this automatically)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/bluelotus

# JWT secret — generate with: openssl rand -hex 32
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# Frontend → API connection
API_URL=http://localhost:8000

# Optional: set to "production" to disable debug features
ENVIRONMENT=development
